generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}

enum AppointmentStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum QueueStatus {
  WAITING
  CALLING
  COMPLETED
  SKIPPED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(RECEPTIONIST)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctor Doctor?
}

model Doctor {
  id              String   @id @default(uuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: Restrict)
  name            String
  specialization  String
  department      String
  consultationFee Float
  experience      Int
  availableFrom   String   @default("09:00")
  availableTo     String   @default("17:00")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  appointments Appointment[]
  queueTokens  QueueToken[]
  @@index([department])
  @@index([specialization])
}

model Patient {
  id             String   @id @default(uuid())
  name           String
  email          String?
  phoneNumber    String   @unique
  age            Int
  gender         String
  medicalHistory String? // Nullable — intentional crash trigger for frontend bug
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  appointments Appointment[]
  queueTokens  QueueToken[]
}

model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  patient         Patient           @relation(fields: [patientId],references: [id],onDelete: Restrict)
  doctorId        String
  doctor          Doctor            @relation(fields: [doctorId],references: [id],onDelete: Restrict)
  appointmentDate DateTime
  reason          String            @default("")
  status          AppointmentStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  queueTokens     QueueToken[]
  @@unique([doctorId, appointmentDate])
  @@index([doctorId, status])
  @@index([patientId])
}

model QueueToken {
  id            String       @id @default(uuid())
  tokenNumber   Int
  patientId     String
  patient       Patient @relation(fields: [patientId],references: [id],onDelete: Restrict)
  doctorId      String
  doctor        Doctor @relation(fields: [doctorId],references: [id],onDelete: Restrict)
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId],references: [id],onDelete: Restrict)
  status        QueueStatus @default(WAITING)
  queueDate     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([doctorId, tokenNumber, queueDate])
  @@index([doctorId, queueDate])
  @@index([status])
}